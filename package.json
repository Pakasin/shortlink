{
  "name": "shortlink-qr-generator",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun run dev",
    "build": "bun run build:shared && bun run build:frontend && bun run build:backend",
    "build:frontend": "cd frontend && bun run build",
    "build:backend": "cd backend && bun run build",
    "build:shared": "cd shared && bun run build",
    "install:all": "bun install && cd shared && bun install && cd ../backend && bun install && cd ../frontend && bun install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
